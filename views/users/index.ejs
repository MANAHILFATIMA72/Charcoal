<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Arial', sans-serif;
    background-color: #f5f5f5;
  }

  .hero-section {
    background: linear-gradient(135deg, #2c2c2c 0%, #3d3d3d 100%);
    color: white;
    text-align: center;
    padding: 60px 20px;
    margin-bottom: 50px;
  }

  .hero-section h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    font-weight: bold;
  }

  .hero-section p {
    font-size: 1.2rem;
    margin-bottom: 20px;
    opacity: 0.9;
  }

  .categories-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
  }

  .section-title {
    text-align: center;
    font-size: 2rem;
    color: #2c2c2c;
    margin-bottom: 40px;
    font-weight: bold;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
    margin-bottom: 60px;
  }

  .category-card {
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
    text-decoration: none;
  }

  .category-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .category-card-image {
    width: 100%;
    height: 250px;
    background: linear-gradient(135deg, #e0e0e0 0%, #f5f5f5 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: #999;
  }

  .category-card-content {
    padding: 20px;
    text-align: center;
  }

  .category-card-name {
    font-size: 1.3rem;
    color: #2c2c2c;
    font-weight: bold;
    margin-bottom: 10px;
  }

  .category-card-button {
    display: inline-block;
    background-color: #2c2c2c;
    color: white;
    padding: 10px 20px;
    border-radius: 5px;
    text-decoration: none;
    transition: background-color 0.3s ease;
    font-size: 0.9rem;
  }

  .category-card-button:hover {
    background-color: #1a1a1a;
  }

  .no-categories {
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .hero-section h1 {
      font-size: 1.8rem;
    }

    .hero-section p {
      font-size: 1rem;
    }

    .section-title {
      font-size: 1.5rem;
    }

    .categories-grid {
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
    }
  }
</style>

<div class="hero-section">
  <h1>Welcome to Charcoal Clothing</h1>
  <p>Discover our exclusive collection of premium men's formal and casual wear</p>
</div>

<div class="categories-section">
  <h2 class="section-title">Shop by Category</h2>

  <% if (categories && categories.length > 0) { %>
    <div class="categories-grid">
      <% categories.forEach(category => { %>
        <a href="/category/<%= category.name %>" class="category-card">
          <div class="category-card-image">
            <i class="fas fa-shopping-bag"></i>
          </div>
          <div class="category-card-content">
            <h3 class="category-card-name"><%= category.name %></h3>
            <span class="category-card-button">View Products</span>
          </div>
        </a>
      <% }) %>
    </div>
  <% } else { %>
    <div class="no-categories">
      <p>No categories available at the moment. Please check back soon!</p>
    </div>
  <% } %>
</div>
